# ─── Required ────────────────────────────────────────────────────────────────

# WalletConnect Project ID
# Get yours free at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
# Set the RPC URL for each chain you want to support.
# You can get free RPC endpoints from Infura (https://infura.io/) or Alchemy (https://www.alchemy.com/)

# Base Sepolia (testnet — recommended for development)
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# BNB Smart Chain (mainnet public RPC)
NEXT_PUBLIC_BNB_RPC_URL=https://bsc-dataseed1.binance.org

# Filecoin
NEXT_PUBLIC_FILECOIN_RPC_URL=https://api.node.glif.io

# Base
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# ─── Optional ────────────────────────────────────────────────────────────────

# Alchemy API key — improves RPC reliability and performance
# Get one at: https://www.alchemy.com/
# ─── Supabase (Off-Chain Records) ─────────────────────────────────────────────
# Get these from your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for server-side verification and auto-setup
# Project Settings -> API -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Required for AUTOMATIC table creation on app run
# IMPORTANT: For Vercel deployment, you MUST use the Connection Pooler URL (Transaction Mode).
# Direct connections (port 5432) often fail on Vercel due to IPv6/Network limitations.
#
# 1. Go to Supabase Dashboard -> Settings -> Database
# 2. Connection string -> URI -> Choose 'Pooler' -> Mode: 'Transaction'
# 3. Use Port 6543 and ensure the username is 'postgres.[YOUR-PROJECT-REF]'
# 
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-REGION].pooler.supabase.com:6543/postgres?sslmode=require
